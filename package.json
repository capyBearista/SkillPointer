{
  "name": "skillcat",
  "version": "0.1.0",
  "description": "SkillCat OpenTUI runtime",
  "type": "module",
  "bin": {
    "skillcat": "./bin/skillcat.mjs"
  },
  "scripts": {
    "skillcat": "node ./bin/skillcat.mjs",
    "tui": "bun run ./opentui/src/index.tsx",
    "tui:dev": "bun --watch run ./opentui/src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"opentui/src/**/*.test.ts\""
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "@xenova/transformers": "^2.17.2",
    "oh-my-logo": "^0.4.0",
    "react": "^19.1.0",
    "stopword": "^3.1.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/stopword": "^2.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "yaml": "^2.8.3"
  }
}
